rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function hasRole(roleName) {
      return request.auth != null
        && exists(/databases/$(database)/documents/roles/$(roleName))
        && request.auth.uid in get(/databases/$(database)/documents/roles/$(roleName)).data;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return hasRole("admin");
    }
    
    function canChat() {
      return hasRole("canChat");
    }

    function canAddPubToPoll() {
      return hasRole("canAddPubToPoll");
    }

    function canCreatePoll() {
      return hasRole("canCreatePoll");
    }

    function canCompletePoll() {
      return hasRole("canCompletePoll");
    }

    function canManagePubs() {
      return hasRole("canManagePubs");
    }

    function canDeleteAnyMessage() {
      return hasRole("canDeleteAnyMessage");
    }

    function canUseNotificationPing() {
      return isAdmin() || canCreatePoll() || canCompletePoll();
    }

    function isValidPublicUserProfileCreate(userId) {
      return request.resource.data.keys().hasOnly(["uid", "name", "photoUrl", "votesVisible"])
        && request.resource.data.uid == userId
        && (!("name" in request.resource.data) || request.resource.data.name is string || request.resource.data.name == null)
        && (!("photoUrl" in request.resource.data) || request.resource.data.photoUrl is string || request.resource.data.photoUrl == null)
        && (!("votesVisible" in request.resource.data) || request.resource.data.votesVisible is bool || request.resource.data.votesVisible == null);
    }

    function isValidPublicUserProfileUpdate(userId) {
      return request.resource.data.uid == userId
        // Permit legacy keys to remain, but only allow changing approved public fields.
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["uid", "name", "photoUrl", "votesVisible"])
        && (!("name" in request.resource.data) || request.resource.data.name is string || request.resource.data.name == null)
        && (!("photoUrl" in request.resource.data) || request.resource.data.photoUrl is string || request.resource.data.photoUrl == null)
        && (!("votesVisible" in request.resource.data) || request.resource.data.votesVisible is bool || request.resource.data.votesVisible == null);
    }
    
    // Polls collection - read for all, update for known users, create/delete for admins
    match /polls/{poll} {
      allow read: if true;
      allow update: if canAddPubToPoll() || canCompletePoll();
      allow create, delete: if canCreatePoll();
    }
    
    // Votes collection - read/update for logged in users, full access for admins
    match /votes/{poll} {
      allow read, update: if request.auth != null;
      allow create, delete: if canCreatePoll();
    }

    // Attendance collection - read/create/update for logged in users, delete for poll creators
    // create is allowed for logged-in users so the fallback initialisation in
    // updateDocWithInitialization succeeds when an attendance doc doesn't exist yet
    // (e.g. polls created before the automatic initialisation was added).
    match /attendance/{poll} {
      allow read, create, update: if request.auth != null;
      allow delete: if canCreatePoll();
    }
    
    // Completed actions collection - admin only
    match /comp_actions/{poll} {
      allow read, write: if canCreatePoll();
    }
    
    // Open actions collection - admin only
    match /open_actions/{poll} {
      allow read, write: if canCreatePoll();
    }

    // Notification request and acknowledgement collections - ping handshake between web app and notifier tool
    match /notification_req/{docId} {
      allow read, write: if canUseNotificationPing();
    }

    match /notification_ack/{docId} {
      allow read: if canUseNotificationPing();
      allow write: if false;
    }
    
    // Pubs collection - read for all, write for admins only
    match /pubs/{pubId} {
      allow read: if true;
      allow create, update, delete: if canManagePubs();
    }
    
    // Roles collection - read for logged in users, write only for admins
    match /roles/{role} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Users collection - private data, restricted to self and admins
    match /users/{userId} {
      // Allow reads by canonical doc ID OR by legacy auto-generated IDs where uid field matches auth uid
      // TODO(remove-legacy-users-read): delete `resource.data.uid == request.auth.uid` after users docs are migrated to canonical users/{uid} IDs.
      allow read: if request.auth != null && (request.auth.uid == userId || resource.data.uid == request.auth.uid || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Users public collection - display profile metadata, readable by all authenticated users
    match /user-public/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && (request.auth.uid == userId || isAdmin())
                    && isValidPublicUserProfileCreate(userId);
      allow update: if request.auth != null
                    && (request.auth.uid == userId || isAdmin())
                    && isValidPublicUserProfileUpdate(userId);
    }
    
    // Messages collection - known users can read/create, admins have full access, users can delete their own
    match /messages/{messageId} {
      allow read: if canChat();
      allow create: if canChat();
      allow delete: if canDeleteAnyMessage() || 
                      (request.auth != null && resource.data.uid == request.auth.uid);
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
